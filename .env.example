ANTHROPIC_API_KEY=sk-ant-...
REPORT_MODEL=claude-sonnet-4-6        # haiku for speed: claude-haiku-4-5-20251001
VISION_MODEL=                          # any-modality vision; blank = use REPORT_MODEL

# MedGemma (Google) for the imaging analysis step — optional.
# Open-weights, reached via an OpenAI-compatible endpoint. When set, MedGemma
# extracts the findings and Claude writes the bilingual report. Leave blank to
# use the built-in analyzers (torchxrayvision for chest + Claude vision).
#   HF Inference Endpoint:  https://<id>.endpoints.huggingface.cloud/v1   (HF token)
#   Vertex AI (OpenAI-compat): https://<region>-aiplatform.googleapis.com/v1/projects/<proj>/locations/<region>/endpoints/openapi  (gcloud access token)
#   self-hosted vLLM/Ollama:   http://localhost:8001/v1
MEDGEMMA_BASE_URL=
MEDGEMMA_API_KEY=
MEDGEMMA_MODEL=google/medgemma-4b-it

ORTHANC_URL=http://localhost:8042
ORTHANC_USER=                          # auth disabled for hackathon
ORTHANC_PASSWORD=

TELEGRAM_BOT_TOKEN=                     # from @BotFather
TELEGRAM_CHAT_ID=                      # your chat/group id

DATABASE_URL=sqlite:///storage/radguard.db
HIGH_RISK_THRESHOLD=70
FRONTEND_ORIGIN=http://localhost:5173
